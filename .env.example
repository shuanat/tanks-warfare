# HTTP + WebSocket (один порт).
# Локально: 3033 (дефолт в server/config.js; в client/.env.development — тот же порт в VITE_WS_URL).
# На VPS с PM2: PORT=80
PORT=3033

# Корень статики: после `npm run build` — папка client/dist.
# На VPS часто: STATIC_ROOT=/var/www/tanks
STATIC_ROOT=

# development | production
NODE_ENV=development
