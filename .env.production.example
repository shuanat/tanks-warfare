# Шаблон для продакшена на VPS (скопировать в `.env` рядом с процессом или задать в PM2 / systemd).
# Секреты в репозиторий не коммитить.

NODE_ENV=production
PORT=80

# Каталог со статикой: index.html и папка assets (часто — содержимое client/dist после сборки).
STATIC_ROOT=/var/www/tanks

# Опционально: error | warn | info | debug (по умолчанию в production — info)
# LOG_LEVEL=info
