{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "noEmitOnError": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "#shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}
